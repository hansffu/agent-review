(ert-deftest agent-review-supports-multiline-comments-with-snapshot ()
  (agent-review-test-with-temp-repo (repo)
    (agent-review-test--write-file (expand-file-name "demo.txt" repo) "one\ntwo\nthree\n")
    (agent-review-test--git repo "add" "demo.txt")
    (agent-review-test--git repo "commit" "-m" "expand diff")
    (let ((default-directory repo)
          (responses '("main" "Multiline note"))
          (buffer nil))
      (cl-letf (((symbol-function 'completing-read)
                 (lambda (&rest _args)
                   (prog1 (car responses)
                     (setq responses (cdr responses)))))
                ((symbol-function 'read-string)
                 (lambda (&rest _args)
                   (prog1 (car responses)
                     (setq responses (cdr responses)))))
                ((symbol-function 'switch-to-buffer)
                 (lambda (buf &rest _) (setq buffer (get-buffer buf))))
                ((symbol-function 'pop-to-buffer)
                 (lambda (buf &rest _) (setq buffer (get-buffer buf)))))
        (setq buffer (agent-review))
        (with-current-buffer buffer
          (goto-char (point-min))
          (re-search-forward "^\\+two$")
          (beginning-of-line)
          (let ((start (point)))
            (re-search-forward "^\\+three$")
            (end-of-line)
            (let ((end (point)))
              (goto-char start)
              (push-mark start t t)
              (goto-char end)
              (setq mark-active t
                    transient-mark-mode t)
              (agent-review-context-comment)))
          (goto-char (point-min))
          (re-search-forward "demo.txt:2-3")
          (re-search-forward "^  @@ .+ @@$"))
        (let* ((review-file (expand-file-name ".agent-review/feature/offline.json" repo))
               (review (agent-review-store-read review-file))
               (thread (car (alist-get 'threads review)))
               (anchor (alist-get 'anchor thread))
               (snapshot (alist-get 'snapshot_diff_hunk thread)))
          (should (equal 2 (alist-get 'start_line anchor)))
          (should (equal "RIGHT" (alist-get 'start_side anchor)))
          (should (equal 3 (alist-get 'line anchor)))
          (should (string-match-p "^@@ .+ @@\n" snapshot))
          (should (string-match-p "^\\+two$" snapshot))
          (should (string-match-p "^\\+three$" snapshot)))))))

(ert-deftest agent-review-continue-marks-stale-thread-outdated ()
  (agent-review-test-with-temp-repo (repo)
    (let* ((head (agent-review-test--git repo "rev-parse" "HEAD"))
           (review-file (expand-file-name ".agent-review/feature/offline.json" repo))
           (review (agent-review-test--sample-review repo "feature/offline" "main" "stale-head" (list head))))
      (setf (alist-get 'threads review)
            '(((thread_id . "thread-stale")
               (state . "open")
               (anchor . ((base_commit . "base-old")
                          (head_commit . "stale-head")
                          (path . "demo.txt")
                          (side . "RIGHT")
                          (line . 2)
                          (diff_hunk . "@@ -1,1 +1,2 @@")))
               (anchor_status . "active")
               (remap_history . nil)
               (messages . nil))))
      (agent-review-test--write-review-file review-file review)
      (let ((default-directory repo)
            (buffer nil)
            (responses '("main" "Continue")))
        (cl-letf (((symbol-function 'completing-read)
                   (lambda (&rest _args)
                     (prog1 (car responses)
                       (setq responses (cdr responses)))))
                  ((symbol-function 'switch-to-buffer)
                   (lambda (buf &rest _) (setq buffer (get-buffer buf))))
                  ((symbol-function 'pop-to-buffer)
                  (lambda (buf &rest _) (setq buffer (get-buffer buf)))))
          (setq buffer (agent-review))
          (with-current-buffer buffer
            (should (string-match-p "\\[open/outdated\\]" (buffer-string)))
            (goto-char (point-min))
            (re-search-forward "^\\[open/outdated\\]")
            (beginning-of-line)
            (let ((section (magit-current-section)))
              (should (eq (eieio-object-class-name section) 'agent-review--thread-section))
              (should (oref section hidden)))))
        (let* ((persisted (agent-review-store-read review-file))
               (thread (car (alist-get 'threads persisted))))
          (should (equal "outdated" (alist-get 'anchor_status thread))))))))

(ert-deftest agent-review-refresh-keeps-remapped-thread-when-current-anchor-matches-head ()
  (agent-review-test-with-temp-repo (repo)
    (let* ((head (agent-review-test--git repo "rev-parse" "HEAD"))
           (review-file (expand-file-name ".agent-review/feature/offline.json" repo))
           (review (agent-review-test--sample-review repo "feature/offline" "main" head (list head))))
      (setf (alist-get 'threads review)
            `(((thread_id . "thread-remapped")
               (state . "open")
               (anchor . ((base_commit . "base-old")
                          (head_commit . "older-head")
                          (path . "demo.txt")
                          (side . "RIGHT")
                          (line . 1)
                          (diff_hunk . "@@ -1,1 +1,2 @@")))
               (current_anchor . ((base_commit . "base-old")
                                  (head_commit . ,head)
                                  (path . "demo.txt")
                                  (side . "RIGHT")
                                  (line . 2)
                                  (diff_hunk . "@@ -1,1 +1,2 @@")))
               (anchor_status . "remapped")
               (remap_history . (((timestamp . "2026-03-29T01:00:00Z")
                                  (result . "remapped")
                                  (method . "line"))))
               (messages . nil))))
      (agent-review-test--write-review-file review-file review)
      (let ((default-directory repo)
            (buffer nil)
            (responses '("main" "Continue")))
        (cl-letf (((symbol-function 'completing-read)
                   (lambda (&rest _args)
                     (prog1 (car responses)
                       (setq responses (cdr responses)))))
                  ((symbol-function 'switch-to-buffer)
                   (lambda (buf &rest _) (setq buffer (get-buffer buf))))
                  ((symbol-function 'pop-to-buffer)
                   (lambda (buf &rest _) (setq buffer (get-buffer buf)))))
          (setq buffer (agent-review))
          (with-current-buffer buffer
            (agent-review-refresh)
            (should (string-match-p "\\[open/remapped\\]" (buffer-string)))))
        (let* ((persisted (agent-review-store-read review-file))
               (thread (car (alist-get 'threads persisted))))
          (should (equal "remapped" (alist-get 'anchor_status thread)))
          (should (equal head
                         (alist-get 'head_commit (alist-get 'current_anchor thread)))))))))

(ert-deftest agent-review-uncommitted-creates-uncommitted-review ()
  "Selecting 'uncommitted' creates a review with review_type uncommitted."
  (agent-review-test-with-temp-repo (repo)
    ;; Add uncommitted change
    (agent-review-test--write-file (expand-file-name "demo.txt" repo) "one\ntwo\nthree\n")
    (let ((default-directory repo)
          (review nil))
      (cl-letf (((symbol-function 'agent-review-git-prompt-base-ref)
                 (lambda (&optional _repo) "uncommitted"))
                ((symbol-function 'agent-review--open-buffer)
                 (lambda (_file r) (setq review r))))
        (agent-review))
      (should review)
      (should (equal "uncommitted" (alist-get 'review_type review)))
      (should (null (alist-get 'base_ref review)))
      (should (null (alist-get 'head_commits review))))))

(ert-deftest agent-review-uncommitted-recompute-always-outdated ()
  "Threads with nil head_commit should always be treated as outdated."
  (let* ((thread `((thread_id . "t1")
                   (state . "open")
                   (anchor_status . "active")
                   (anchor . ((base_commit . "abc123")
                              (head_commit . nil)
                              (path . "demo.txt")
                              (side . "RIGHT")
                              (line . 2)
                              (diff_hunk . "@@ -1 +1,2 @@")))))
         (result (agent-review--recompute-thread-status thread "def456")))
    (should (equal "outdated" (alist-get 'anchor_status result)))))

(ert-deftest agent-review-uncommitted-refresh-skips-head-update ()
  "Refresh should not update head_ref or head_commits for uncommitted reviews."
  (agent-review-test-with-temp-repo (repo)
    (agent-review-test--write-file (expand-file-name "demo.txt" repo) "one\ntwo\nthree\n")
    (let ((review (agent-review-store-create repo "feature/offline" nil nil nil "uncommitted")))
      (setq review (agent-review--refresh-review-state review repo))
      (should (null (alist-get 'head_ref review)))
      (should (null (alist-get 'head_commits review))))))


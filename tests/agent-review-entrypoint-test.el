(ert-deftest agent-review-continues-or-replaces-existing-review ()
  (should (fboundp 'agent-review-store-read))
  (agent-review-test-with-temp-repo (repo)
    (let* ((head (agent-review-test--git repo "rev-parse" "HEAD"))
           (review-file (expand-file-name ".agent-review/feature/offline.json" repo))
           (seed (agent-review-test--sample-review repo "feature/offline" "main" head (list head))))
      (setf (alist-get 'events seed)
            '(((kind . "created")
               (created_at . "2026-03-29T00:00:00Z"))
              ((kind . "thread_replied")
               (created_at . "2026-03-29T00:05:00Z")
               (thread_id . "thread-seed"))))
      (agent-review-test--write-review-file review-file seed)
      (let ((default-directory repo)
            (continue-buffer nil)
            (responses '("main" "Continue")))
        (cl-letf (((symbol-function 'completing-read)
                   (lambda (&rest _args)
                     (prog1 (car responses)
                       (setq responses (cdr responses)))))
                  ((symbol-function 'switch-to-buffer)
                   (lambda (buf &rest _) (setq continue-buffer (get-buffer buf))))
                  ((symbol-function 'pop-to-buffer)
                   (lambda (buf &rest _) (setq continue-buffer (get-buffer buf)))))
          (setq continue-buffer (agent-review))
          (with-current-buffer continue-buffer
            (should (string-match-p "Base: main" (buffer-string)))))
        (should (equal "review-seed"
                       (alist-get 'review_id (agent-review-store-read review-file)))))
      (let ((default-directory repo)
            (replace-buffer nil)
            (responses '("HEAD~1" "Replace")))
        (cl-letf (((symbol-function 'completing-read)
                   (lambda (&rest _args)
                     (prog1 (car responses)
                       (setq responses (cdr responses)))))
                  ((symbol-function 'switch-to-buffer)
                   (lambda (buf &rest _) (setq replace-buffer (get-buffer buf))))
                  ((symbol-function 'pop-to-buffer)
                   (lambda (buf &rest _) (setq replace-buffer (get-buffer buf)))))
          (setq replace-buffer (agent-review))
          (with-current-buffer replace-buffer
            (should (string-match-p "Base: HEAD~1" (buffer-string)))))
        (let ((review (agent-review-store-read review-file)))
          (should (equal "HEAD~1" (alist-get 'base_ref review)))
          (should-not (equal "review-seed" (alist-get 'review_id review)))
          (should (equal '("created" "thread_replied" "created" "replaced")
                         (mapcar (lambda (event) (alist-get 'kind event))
                                 (alist-get 'events review)))))))))


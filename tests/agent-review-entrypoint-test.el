(ert-deftest agent-review-context-commands-persist-immediately ()
  (should (fboundp 'agent-review-context-comment))
  (should (fboundp 'agent-review-toggle-thread-state))
  (agent-review-test-with-temp-repo (repo)
    (let ((default-directory repo)
          (responses '("main" "Needs attention" "Reply from agent"))
          (buffer nil))
      (cl-letf (((symbol-function 'completing-read)
                 (lambda (&rest _args)
                   (prog1 (car responses)
                     (setq responses (cdr responses)))))
                ((symbol-function 'read-string)
                 (lambda (&rest _args)
                   (prog1 (car responses)
                     (setq responses (cdr responses)))))
                ((symbol-function 'switch-to-buffer)
                 (lambda (buf &rest _) (setq buffer (get-buffer buf))))
                ((symbol-function 'pop-to-buffer)
                 (lambda (buf &rest _) (setq buffer (get-buffer buf)))))
        (setq buffer (agent-review))
        (with-current-buffer buffer
          (goto-char (point-min))
          (search-forward "+two")
          (beginning-of-line)
          (agent-review-context-comment)
          (goto-char (point-min))
          (search-forward "Needs attention")
          (beginning-of-line)
          (agent-review-context-comment)
          (agent-review-toggle-thread-state))
        (let* ((review-file (expand-file-name ".agent-review/feature/offline.json" repo))
               (review (agent-review-store-read review-file))
               (thread (car (alist-get 'threads review))))
          (should (equal 1 (length (alist-get 'threads review))))
          (should (equal 2 (length (alist-get 'messages thread))))
          (should (equal "resolved" (alist-get 'state thread))))))))


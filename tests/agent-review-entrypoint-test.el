;;; agent-review-entrypoint-test.el --- Entrypoint tests -*- lexical-binding: t; -*-

(require 'test-helper)

(defun agent-review-test--face-contains-p (property face)
  "Return non-nil when PROPERTY includes FACE."
  (cond
   ((eq property face) t)
   ((listp property) (memq face property))
   (t nil)))

(ert-deftest agent-review-creates-a-new-offline-review ()
  (should (fboundp 'agent-review))
  (agent-review-test-with-temp-repo (repo)
    (let ((default-directory repo)
          (buffer nil))
      (cl-letf (((symbol-function 'completing-read)
                 (lambda (&rest _args) "main"))
                ((symbol-function 'switch-to-buffer)
                 (lambda (buf &rest _)
                   (setq buffer (get-buffer buf))))
                ((symbol-function 'pop-to-buffer)
                 (lambda (buf &rest _)
                   (setq buffer (get-buffer buf)))))
        (setq buffer (agent-review))
        (should (buffer-live-p buffer))
        (with-current-buffer buffer
          (should (derived-mode-p 'agent-review-mode))
          (should (string-match-p "Base: main" (buffer-string)))
          (should (string-match-p "Total 1 commits" (buffer-string)))
          (should (string-match-p "Files changed (1 files; 1 additions, 0 deletions)" (buffer-string)))
          (should (string-match-p "modified\\s-+a/demo.txt -> b/demo.txt" (buffer-string)))))
      (let ((review-file (expand-file-name ".agent-review/feature/offline.json" repo)))
        (should (file-exists-p review-file))))))

(ert-deftest agent-review-renders-styled-metadata-and-diff ()
  (agent-review-test-with-temp-repo (repo)
    (let ((default-directory repo)
          (buffer nil))
      (cl-letf (((symbol-function 'completing-read)
                 (lambda (&rest _args) "main"))
                ((symbol-function 'switch-to-buffer)
                 (lambda (buf &rest _)
                   (setq buffer (get-buffer buf))))
                ((symbol-function 'pop-to-buffer)
                 (lambda (buf &rest _)
                   (setq buffer (get-buffer buf)))))
        (setq buffer (agent-review))
        (with-current-buffer buffer
          (goto-char (point-min))
          (search-forward "Agent Review:")
